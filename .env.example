# Contract integration mode: local | onchain
VITE_CONTRACT_MODE=local

# Required only when VITE_CONTRACT_MODE=onchain
VITE_FORWARD_APP_ID=0

# ---------------------------
# Backend script configuration (deploy/oracle/e2e)
# ---------------------------
