VITE_ALGOD_TOKEN=
VITE_ALGOD_PORT=
VITE_INDEXER_TOKEN=
VITE_INDEXER_PORT=

# AlphaVantage API Key for commodity price data
# Get your free API key from: https://www.alphavantage.co/support/#api-key
