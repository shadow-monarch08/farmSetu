ALGOD_TOKEN=
ALGOD_PORT=

# Contract lifecycle defaults
CROP_NAME=WHEAT
QUANTITY=100
AGREED_PRICE=10
UPDATED_PRICE=12
CURRENT_PRICE=12

# Optional direct app usage
APP_ID=0
ORACLE_ADDRESS=

# Wallet mnemonics (DO NOT COMMIT REAL VALUES)
